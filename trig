import sys
import math

# 引数が足りない場合の対策
if len(sys.argv) < 3:
    print("使い方: ./trig [sin|cos|tan] [角度]", file=sys.stderr)
    sys.exit(1)

# データの取り出し
func = sys.argv[1]

# 角度の数値変換とエラーチェック
try:
    angle_deg = float(sys.argv[2])
except ValueError:
    print("エラー: 角度には数値を入力してください", file=sys.stderr)
    sys.exit(1)

# ラジアン変換
angle_rad = math.radians(angle_deg)

# 関数の判定と計算実行
if func == "sin":
    print(math.sin(angle_rad))
elif func == "cos":
    print(math.cos(angle_rad))
elif func == "tan":
    print(math.tan(angle_rad))
else:
    print(f"エラー: {func} は未対応です", file=sys.stderr)
    sys.exit(1)
