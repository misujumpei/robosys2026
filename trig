import sys
import math

# 引数が足りない場合の対策
if len(sys.argv) < 3:
    print("使い方: ./trig [sin|cos|tan] [角度]")
    sys.exit(1)

#  データの取り出しとエラーチェック 
func = sys.argv[1]

try:
    # ここで数値変換（記号や文字だとここで except に飛ぶ）
    angle_deg = float(sys.argv[2])
except ValueError:
    print("エラー: 角度には数値を入力してください")
    sys.exit(1)

# --- 3. 計算の準備（ラジアン変換） ---
angle_rad = math.radians(angle_deg)

# --- 4. 実際の計算と表示 ---
if func == "sin":
    print(math.sin(angle_rad))
elif func == "cos":
    print(math.cos(angle_rad))
elif func == "tan":
    print(math.tan(angle_rad))
else:
    print(f"エラー: {func} は未対応です") 
